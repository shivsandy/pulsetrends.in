# ═══════════════════════════════════════════════════════════════════════════
#  PULSETRENDS.IN — Environment Variables
# ═══════════════════════════════════════════════════════════════════════════
#  Copy this file to `.env` and fill in your API keys.
#  cp .env.example .env
# ═══════════════════════════════════════════════════════════════════════════

# ─── PRIMARY AI ANALYSIS (DeepSeek V4 Flash Free via OpenRouter) ──────────
# Used by: scripts/ai_analysis_hub.py (--ipo, --crypto, --stocks, --scores)
#          scripts/generate_missing_ipo_scores.py
ZEN_API_KEY=

# ─── SECONDARY AI ANALYSIS (OpenRouter — 8 Keys with Free Models) ─────────
# Used by: scripts/ai_analysis_hub.py, scripts/gen_ai_analysis.py,
#          crypto_analyzer.py, airdrop_pipeline.py
#
# Model assignments:
#   OPENROUTER_API_1 → nex-agi/nex-n2-pro:free
#   OPENROUTER_API_2 → nvidia/nemotron-3.5-content-safety:free
#   OPENROUTER_API_3 → nvidia/nemotron-3-ultra-550b-a55b:free
#   OPENROUTER_API_4 → nvidia/nemotron-3-nano-omni-30b-a3b-reasoning:free
#   OPENROUTER_API_5 → poolside/laguna-xs.2:free
#   OPENROUTER_API_6 → poolside/laguna-m.1:free
#   OPENROUTER_API_7 → google/gemma-4-26b-a4b-it:free
#   OPENROUTER_API_8 → google/gemma-4-31b-it:free
# Get keys: https://openrouter.ai/keys
OPENROUTER_API_1=
OPENROUTER_API_2=
OPENROUTER_API_3=
OPENROUTER_API_4=
OPENROUTER_API_5=
OPENROUTER_API_6=
OPENROUTER_API_7=
OPENROUTER_API_8=

# ─── NEWS GENERATION AI MODELS ────────────────────────────────────────────
# Used by: scripts/ai_analysis_hub.py (news generation)
#          scripts/generate-daily-news.py

# ZEN_API_KEY2 — DeepSeek V4 Flash Free for news generation
ZEN_API_KEY2=

# Cohere (command-r-plus-08-2024)
COHERE_API=

# Groq (llama-3.3-70b-versatile)
GROQ_API=

# Mistral (mistral-large-latest)
MISTRAL_API=

# NVIDIA AI (nemotron models)
NVIDIA_API_KEY_1=

# Google Gemini (gemini-2.0-flash)
GOOGLE_AI_API_KEY_1=
GOOGLE_AI_API_KEY_2=

# ─── FINNHUB API — US IPO Calendar & Market Data ─────────────────────────
# Used by: scanners/us.py, ipo_scraper.py, news_api.py
# Get keys: https://finnhub.io/register (free tier: 60 calls/min)
# 5 keys for rotation (rate limit handling)
FINNHUB_API_KEY_1=
FINNHUB_API_KEY_2=
FINNHUB_API_KEY_3=
FINNHUB_API_KEY_4=
FINNHUB_API_KEY_5=

# ─── NEWS API — Stock & Market News ──────────────────────────────────────
# Used by: generate_data_ts.py, news_api.py
# Get key: https://newsapi.org/register
NEWSAPI_KEY=

# ─── UNSPLASH — Images for News Articles ─────────────────────────────────
# Used by: scripts/generate-daily-news.py
# Get keys: https://unsplash.com/developers
UNSPLASH_ACCESS_KEY_1=
UNSPLASH_ACCESS_KEY_2=
UNSPLASH_ACCESS_KEY_3=

# ─── ETHERSCAN — Blockchain Data ─────────────────────────────────────────
# Used by: airdrop/dapps data collection
ETHERSCAN_API_KEY=
